<UserControl x:Class="Measurement_MC_App.Views.VisionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:vision="clr-namespace:Measurement_MC_App.Models"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Measurement_MC_App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="Transparent">

    <UserControl.Resources>

        <!-- Converter -->
        <vm:EnumEqualsConverter x:Key="EnumEquals"/>

        <!-- Typography -->
        <Style x:Key="H1" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TxtH1}"/>
        <Style x:Key="H2" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TxtH2}"/>
        <Style x:Key="Muted" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource TxtMuted}"/>

        <!-- ===== Button compact (gọn hơn) ===== -->
        <Style x:Key="Btn" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.90"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Mode button (FIX lẹm) ===== -->
        <Style x:Key="ModeBtn" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="#18FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <!-- ClipToBounds để không “thò/lẹm” -->
                        <Border x:Name="Bd"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                ClipToBounds="True">

                            <!-- giảm margin nội bộ để tránh cắt -->
                            <Grid Margin="10,0,10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- indicator -->
                                <Border x:Name="DotHost"
                                        Width="18" Height="18"
                                        CornerRadius="9"
                                        Background="#10FFFFFF"
                                        BorderBrush="#18FFFFFF"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <Ellipse x:Name="Dot" Width="8" Height="8"
                                             Fill="{DynamicResource Text2Brush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>

                                <!-- text -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <ContentPresenter/>
                                    <TextBlock x:Name="Hint"
                                               Text="Tap to apply"
                                               Foreground="{DynamicResource Text2Brush}"
                                               FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- arrow -->
                                <Path x:Name="Arrow"
                                      Grid.Column="3"
                                      Width="10" Height="10"
                                      Margin="8,0,0,0"
                                      Data="M3,1 L7,5 L3,9"
                                      Stroke="{DynamicResource Text2Brush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                <Setter TargetName="Hint" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="DotHost" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Dot" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Hint" Property="Text" Value="Selected"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Fields ===== -->
        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TextField" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Badge" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Background" Value="#10FFFFFF"/>
            <Setter Property="BorderBrush" Value="#14FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <!-- giữ SquareHost như bạn có -->
        <Style x:Key="SquareHost" TargetType="{x:Type Grid}">
            <Setter Property="Height" Value="{Binding ActualWidth, RelativeSource={RelativeSource Mode=Self}}"/>
        </Style>

        <!-- slider gọn hơn -->
        <Style TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

    </UserControl.Resources>

    <UserControl.DataContext>
        <vm:VisionViewModel/>
    </UserControl.DataContext>

    <!-- =================== LAYOUT =================== -->
    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="14"/>
            <!-- FIX: cột phải cố định cho gọn, không “dài” cảm giác -->
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT PREVIEW ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="300"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource SCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Vision Preview" Style="{StaticResource H1}" VerticalAlignment="Center"/>

                        <Border Grid.Column="1" Style="{StaticResource Badge}" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{DynamicResource GoodBrush}"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="LIVE"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Column="3"
                                   Text="{Binding PreviewTitle}"
                                   Style="{StaticResource Muted}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Grid.Row="2" Style="{DynamicResource SPanel}" Padding="12">
                        <Border CornerRadius="16"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="#14FFFFFF"
                                BorderThickness="1"
                                ClipToBounds="True">
                            <Image Source="{Binding PreviewImage}" Stretch="Uniform"/>
                        </Border>
                    </Border>

                    <Border Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource Badge}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{Binding Blur, StringFormat=Blur: \{0\}}"/>

                            <TextBlock Grid.Column="2"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="Canny: {0} / {1}">
                                        <Binding Path="CannyLow"/>
                                        <Binding Path="CannyHigh"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <TextBlock Grid.Column="4"
                                       Foreground="{DynamicResource Text2Brush}"
                                       FontWeight="SemiBold"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{Binding SelectedMode, StringFormat=Mode: \{0\}}"/>

                            <TextBlock Grid.Column="5"
                                       Text="Latency: 6ms"
                                       Foreground="{DynamicResource Text2Brush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Bottom CALIB + NORMAL -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CALIB -->
                <Border Grid.Column="0" Style="{DynamicResource SCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CALIB" Style="{StaticResource H2}"/>
                            <TextBlock Grid.Column="1" Text="Image / Edges" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Grid.Row="2" Style="{DynamicResource SPanel}" Padding="12" Background="{DynamicResource Surface2Brush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Image" Style="{StaticResource FieldLabel}" Margin="2,0,0,8"/>
                                    <Grid Style="{StaticResource SquareHost}">
                                        <Border CornerRadius="16"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="#14FFFFFF"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Image Source="{Binding CalibImage}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding SelectPreviewCommand}"
                                                CommandParameter="{x:Static vision:PreviewSlot.CalibImage}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Edges" Style="{StaticResource FieldLabel}" Margin="2,0,0,8"/>
                                    <Grid Style="{StaticResource SquareHost}">
                                        <Border CornerRadius="16"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="#14FFFFFF"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Image Source="{Binding CalibEdges}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding SelectPreviewCommand}"
                                                CommandParameter="{x:Static vision:PreviewSlot.CalibEdges}"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- NORMAL -->
                <Border Grid.Column="2" Style="{DynamicResource SCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="NORMAL" Style="{StaticResource H2}"/>
                            <TextBlock Grid.Column="1" Text="Image / Edges" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Grid.Row="2" Style="{DynamicResource SPanel}" Padding="12" Background="{DynamicResource Surface2Brush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Image" Style="{StaticResource FieldLabel}" Margin="2,0,0,8"/>
                                    <Grid Style="{StaticResource SquareHost}">
                                        <Border CornerRadius="16"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="#14FFFFFF"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Image Source="{Binding NormalImage}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding SelectPreviewCommand}"
                                                CommandParameter="{x:Static vision:PreviewSlot.NormalImage}"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Edges" Style="{StaticResource FieldLabel}" Margin="2,0,0,8"/>
                                    <Grid Style="{StaticResource SquareHost}">
                                        <Border CornerRadius="16"
                                                Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="#14FFFFFF"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Image Source="{Binding NormalEdges}" Stretch="UniformToFill"/>
                                        </Border>
                                        <Button Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding SelectPreviewCommand}"
                                                CommandParameter="{x:Static vision:PreviewSlot.NormalEdges}"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== RIGHT (COMPACT) ===== -->
        <ScrollViewer Grid.Column="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,10,0">
            <StackPanel>

                <!-- Parameters -->
                <Border Style="{DynamicResource SCard}">
                    <StackPanel>
                        <TextBlock Text="Parameters" Style="{StaticResource H1}"/>
                        <TextBlock Text="Save/Load tuning and calibration parameters" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        <Border Style="{StaticResource SepLine}"/>

                        <UniformGrid Columns="2" Rows="2" Margin="0,8,0,0">
                            <Button Style="{StaticResource Btn}" Content="Save Tuning" Margin="0,0,10,10"/>
                            <Button Style="{StaticResource Btn}" Content="Load Tuning" Margin="0,0,0,10"/>
                            <Button Style="{StaticResource Btn}" Content="Save Calib" Margin="0,0,10,0"/>
                            <Button Style="{StaticResource Btn}" Content="Load Calib"/>
                        </UniformGrid>

                        <Border Height="6" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <Border Height="12" Background="Transparent"/>

                <!-- Mode (FIX lệch/lẹm) -->
                <Border Style="{DynamicResource SCard}">
                    <StackPanel>
                        <TextBlock Text="Mode" Style="{StaticResource H1}"/>
                        <TextBlock Text="Select operating mode" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        <Border Style="{StaticResource SepLine}"/>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton Grid.Column="0"
                                          Style="{StaticResource ModeBtn}"
                                          Content="Calibration"
                                          Command="{Binding SetModeCommand}"
                                          CommandParameter="{x:Static vm:OperatingMode.Calibration}">
                                <ToggleButton.IsChecked>
                                    <Binding Path="SelectedMode" ConverterParameter="{x:Static vm:OperatingMode.Calibration}">
                                        <Binding.Converter>
                                            <vm:EnumEqualsConverter/>
                                        </Binding.Converter>
                                    </Binding>
                                </ToggleButton.IsChecked>
                            </ToggleButton>

                            <ToggleButton Grid.Column="2"
                                          Style="{StaticResource ModeBtn}"
                                          Content="Normal"
                                          Command="{Binding SetModeCommand}"
                                          CommandParameter="{x:Static vm:OperatingMode.Normal}">
                                <ToggleButton.IsChecked>
                                    <Binding Path="SelectedMode" ConverterParameter="{x:Static vm:OperatingMode.Normal}">
                                        <Binding.Converter>
                                            <vm:EnumEqualsConverter/>
                                        </Binding.Converter>
                                    </Binding>
                                </ToggleButton.IsChecked>
                            </ToggleButton>
                        </Grid>

                        <Border Height="6" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <Border Height="12" Background="Transparent"/>

                <!-- Tuning (gọn) -->
                <Border Style="{DynamicResource SCard}">
                    <StackPanel>
                        <TextBlock Text="Tuning" Style="{StaticResource H1}"/>
                        <TextBlock Text="Blur + Canny thresholds" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        <Border Style="{StaticResource SepLine}"/>

                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Blur (0 → 21)" Style="{StaticResource FieldLabel}"/>
                                <Slider Minimum="0" Maximum="21"
                                        Value="{Binding Blur, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <TextBox Grid.Column="2"
                                     Style="{StaticResource TextField}"
                                     Text="{Binding Blur}"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Canny Low (0 → 255)" Style="{StaticResource FieldLabel}"/>
                                <Slider Minimum="0" Maximum="255"
                                        Value="{Binding CannyLow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <TextBox Grid.Column="2"
                                     Style="{StaticResource TextField}"
                                     Text="{Binding CannyLow}"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Canny High (0 → 255)" Style="{StaticResource FieldLabel}"/>
                                <Slider Minimum="0" Maximum="255"
                                        Value="{Binding CannyHigh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <TextBox Grid.Column="2"
                                     Style="{StaticResource TextField}"
                                     Text="{Binding CannyHigh}"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Height="12" Background="Transparent"/>

                <!-- Reference -->
                <Border Style="{DynamicResource SCard}">
                    <StackPanel>
                        <TextBlock Text="Reference (mm)" Style="{StaticResource H1}"/>
                        <TextBlock Text="Reference values for scaling/checking" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                        <Border Style="{StaticResource SepLine}"/>

                        <Grid Margin="0,10,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Ref Width (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource TextField}"
                                         Text="{Binding RefWidthMm, Mode=TwoWay, StringFormat=F2, UpdateSourceTrigger=LostFocus}"
                                         HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Ref Height (mm)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource TextField}"
                                         Text="{Binding RefHeightMm, Mode=TwoWay, StringFormat=F2, UpdateSourceTrigger=LostFocus}"
                                         HorizontalContentAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Apply Reference"
                                Command="{Binding ApplyReferenceCommand}"
                                Style="{StaticResource Btn}"/>

                        <Border Height="6" Background="Transparent"/>
                    </StackPanel>
                </Border>

                <Border Height="10" Background="Transparent"/>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>
