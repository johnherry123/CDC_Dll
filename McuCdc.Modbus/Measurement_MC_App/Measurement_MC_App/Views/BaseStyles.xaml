<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <CornerRadius x:Key="R12">12</CornerRadius>
    <CornerRadius x:Key="R16">16</CornerRadius>
    <CornerRadius x:Key="R20">20</CornerRadius>

    <Thickness x:Key="PadCard">16</Thickness>
    <Thickness x:Key="PadPanel">14</Thickness>


    <Style x:Key="TxtH1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <Style x:Key="TxtH2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    </Style>

    <Style x:Key="TxtMuted" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
    </Style>

    
    <Style x:Key="SCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource R20}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#12000000"/>
        <Setter Property="Padding" Value="{StaticResource PadCard}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="SPanel" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource R16}"/>
        <Setter Property="Background" Value="{DynamicResource CanvasBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#10FFFFFF"/>
        <Setter Property="Padding" Value="{StaticResource PadPanel}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    
    <Style x:Key="SepLine" TargetType="Border">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="#12FFFFFF"/>
        <Setter Property="Margin" Value="0,10,0,10"/>
    </Style>
    <Style x:Key="SSubCard" TargetType="Border" BasedOn="{StaticResource SCard}">
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="BorderBrush" Value="#12FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
    </Style>

</ResourceDictionary>
