<UserControl x:Class="Measurement_MC_App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Measurement_MC_App.ViewModels"
             xmlns:conv="clr-namespace:Measurement_MC_App.Logic.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

   


    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ===== Typography ===== -->
        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ===== Cards ===== -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style x:Key="SubCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <!-- ===== Inputs ===== -->
        <Style x:Key="TextField" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Buttons ===== -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style x:Key="ToolBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ===== ComboBox modern (FIX: MinWidth=0 để không đè) ===== -->
        <Style x:Key="ComboField" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    CornerRadius="12"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>

                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Focusable="False"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Cursor="Hand">
                                    <Viewbox Width="14" Height="14">
                                        <Path Data="M7,10 L12,5 L2,5 Z"
                                              Fill="{DynamicResource Text2Brush}"/>
                                    </Viewbox>
                                </ToggleButton>
                            </Grid>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Margin="0,6,0,0"
                                        CornerRadius="12"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush2}"
                                        BorderThickness="1"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="280"
                                                  Padding="6"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Model list ===== -->
        <Style x:Key="ModelList" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="14"
                                Padding="12"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderBrush2}"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Search box ===== -->
        <ControlTemplate x:Key="SearchTemplate" TargetType="TextBox">
            <Border x:Name="Bd"
                    CornerRadius="12"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <Grid Margin="10,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Path Width="14" Height="14"
                          VerticalAlignment="Center"
                          Fill="{DynamicResource Text2Brush}"
                          Data="M10.5,2 A8.5,8.5 0 1 0 10.5,19 A8.5,8.5 0 1 0 10.5,2 Z M10.5,4 A6.5,6.5 0 1 1 10.5,17 A6.5,6.5 0 1 1 10.5,4 Z M17,17 L22,22 L20.6,23.4 L15.6,18.4 Z"/>

                    <ScrollViewer Grid.Column="1" x:Name="PART_ContentHost"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="SearchBox" TargetType="TextBox" BasedOn="{StaticResource TextField}">
            <Setter Property="Template" Value="{StaticResource SearchTemplate}"/>
        </Style>
    </UserControl.Resources>

    <!-- ================= LAYOUT ================= -->
    <Grid Margin="18" Grid.IsSharedSizeScope="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="560"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <TextBlock Style="{StaticResource H1}" Text="System Settings" Margin="0,0,0,12"/>

                    <!-- COM -->
                    <Border Style="{StaticResource SubCard}" Padding="14" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource H2}" Text="COM Connection"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Port -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource Label}" Text="Port"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0"
                                                  Style="{StaticResource ComboField}"
                                                  MinWidth="0"
                                                  ItemsSource="{Binding AvailableComPorts}"
                                                  SelectedItem="{Binding ComPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="False"/>

                                        <Button Grid.Column="2"
                                                Width="36" Height="36"
                                                Style="{StaticResource Btn}"
                                                Padding="0"
                                                ToolTip="Refresh COM ports"
                                                Command="{Binding RefreshComPortsCommand}">
                                            <Viewbox Width="16" Height="16">
                                                <Path Stroke="{DynamicResource TextBrush}"
                                                      StrokeThickness="2"
                                                      StrokeLineJoin="Round"
                                                      Data="M20 12a8 8 0 1 1-2.34-5.66 M20 4v6h-6"/>
                                            </Viewbox>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <!-- Baud -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource Label}" Text="Baudrate"/>
                                    <ComboBox Style="{StaticResource ComboField}"
                                              MinWidth="0"
                                              ItemsSource="{Binding AvailableBaudRates}"
                                              SelectedItem="{Binding ComBaud, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="False"
                                              IsTextSearchEnabled="True"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource Hint}" Text="Apply COM settings"/>
                                <Button Grid.Column="2" Style="{StaticResource BtnPrimary}" Content="SET COM"
                                        Command="{Binding SetComCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- TCP -->
                    <Border Style="{StaticResource SubCard}" Padding="14" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource H2}" Text="TCP Connection"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource Label}" Text="Host"/>
                                    <TextBox Style="{StaticResource TextField}"
                                             Text="{Binding TcpHost, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource Label}" Text="Port"/>
                                    <TextBox Style="{StaticResource TextField}"
                                             Text="{Binding TcpPort, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource Hint}" Text="Apply TCP settings"/>
                                <Button Grid.Column="2" Style="{StaticResource BtnPrimary}" Content="SET TCP"
                                        Command="{Binding SetTcpCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- MOTOR -->
                    <Border Style="{StaticResource SubCard}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource H2}" Text="Motor Axis"/>

                            <StackPanel Grid.Row="2">
                                <TextBlock Style="{StaticResource Label}" Text="Speed (X / Y / Z)"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Style="{StaticResource TextField}"
                                             Text="{Binding Motor.SpeedX, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource TextField}"
                                             Text="{Binding Motor.SpeedY, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="4" Style="{StaticResource TextField}"
                                             Text="{Binding Motor.SpeedZ, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="4">
                                <TextBlock Style="{StaticResource Label}" Text="Max (X / Y / Z)"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Style="{StaticResource TextField}"
                                             Text="{Binding Motor.MaxX, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource TextField}"
                                             Text="{Binding Motor.MaxY, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="4" Style="{StaticResource TextField}"
                                             Text="{Binding Motor.MaxZ, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource Hint}" Text="Apply motor settings"/>
                                <Button Grid.Column="2" Style="{StaticResource BtnPrimary}" Content="SET MOTOR"
                                        Command="{Binding SetMotorCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- RIGHT -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource H1}" Text="Model Spec"/>
                    <Button Grid.Column="2" Style="{StaticResource BtnPrimary}" Content="SELECT"
                            Command="{Binding SelectCommand}"/>
                </Grid>

                <!-- Body -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="460"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LIST -->
                    <Border Grid.Column="0" Style="{StaticResource SubCard}" Padding="14">
                        <DockPanel LastChildFill="True">

                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource Label}" Text="Search"/>
                                <TextBox Style="{StaticResource SearchBox}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Style="{StaticResource ToolBtn}" Content="New" Command="{Binding NewModelCommand}"/>
                                <Button Grid.Column="2" Style="{StaticResource ToolBtn}" Content="Edit" Command="{Binding EditCommand}"/>
                                <Button Grid.Column="4" Style="{StaticResource ToolBtn}" Content="Delete" Command="{Binding DeleteCommand}"/>
                            </Grid>

                            <ListBox Style="{StaticResource ModelList}"
                                     ItemsSource="{Binding ModelsView}"
                                     SelectedItem="{Binding SelectedModel}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Foreground="{DynamicResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Text="{Binding Name}"/>

                                            <TextBlock Grid.Row="1"
                                                       Margin="0,6,0,0"
                                                       Foreground="{DynamicResource Text2Brush}"
                                                       FontSize="12"
                                                       Text="{Binding Description}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                        </DockPanel>
                    </Border>

                    <!-- EDITOR -->
                    <Border Grid.Column="2" Style="{StaticResource SubCard}" Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Style="{StaticResource H2}" Text="Editor"/>
                                    <Button Grid.Column="2" Style="{StaticResource BtnPrimary}" Content="SAVE"
                                            Command="{Binding SaveCommand}"
                                            IsEnabled="{Binding IsEditing}"/>
                                </Grid>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Style="{StaticResource Label}" Text="Name"/>
                                    <TextBox Style="{StaticResource TextField}"
                                             Text="{Binding EditorModel.Name, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsEditing}"/>
                                </StackPanel>

                                <Border Style="{StaticResource SubCard}" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Label}" Text="Nominal (mm)"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox Style="{StaticResource TextField}"
                                                     Text="{Binding EditorModel.NominalX, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IsEditing}"/>
                                            <TextBox Grid.Column="2" Style="{StaticResource TextField}"
                                                     Text="{Binding EditorModel.NominalY, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IsEditing}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SubCard}" Padding="12">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource Label}" Text="Tolerance (mm) (+ / -)"/>

                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="X" Foreground="{DynamicResource TextBrush}"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"/>

                                            <TextBox Grid.Column="1" Style="{StaticResource TextField}"
                                                     Text="{Binding EditorModel.TolXPlus, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IsEditing}"/>

                                            <TextBox Grid.Column="3" Style="{StaticResource TextField}"
                                                     Text="{Binding EditorModel.TolXMinus, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IsEditing}"/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Y" Foreground="{DynamicResource TextBrush}"
                                                       VerticalAlignment="Center" FontWeight="SemiBold"/>

                                            <TextBox Grid.Column="1" Style="{StaticResource TextField}"
                                                     Text="{Binding EditorModel.TolYPlus, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IsEditing}"/>

                                            <TextBox Grid.Column="3" Style="{StaticResource TextField}"
                                                     Text="{Binding EditorModel.TolYMinus, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding IsEditing}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
