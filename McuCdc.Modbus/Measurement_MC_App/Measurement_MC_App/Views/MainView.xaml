<UserControl x:Class="Measurement_MC_App.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Background="Transparent">

    <UserControl.Resources>

   
        <Style x:Key="ThinCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#10FFFFFF"/>
            <Setter Property="BorderThickness" Value="0.6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style x:Key="ThinPanel" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="#0CFFFFFF"/>
            <Setter Property="BorderThickness" Value="0.6"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="TrayTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>


        <Style x:Key="ClearBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TrayCellTemplate">
          
            <Button Style="{StaticResource ClearBtn}"
                    Command="{Binding DataContext.CellClickedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
                <Border x:Name="Px"
                        Margin="0.7"
                        CornerRadius="2"
                        Background="#263247"/>
            </Button>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Ok">
                    <Setter TargetName="Px" Property="Background" Value="#22C55E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Ng">
                    <Setter TargetName="Px" Property="Background" Value="#EF4444"/>
                </DataTrigger>
            
                <DataTrigger Binding="{Binding State}" Value="Default">
                    <Setter TargetName="Px" Property="Background" Value="#263247"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="TrayBoardTemplate">
          
            <Button Style="{StaticResource ClearBtn}"
                    Command="{Binding DataContext.TrayClickedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}">
                <Border CornerRadius="12"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="#10FFFFFF"
                        BorderThickness="0.6"
                        Padding="8"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Title}" Style="{StaticResource TrayTitle}" Margin="2,0,0,0"/>

                       
                        <Border Grid.Row="2"
                                CornerRadius="10"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="#0CFFFFFF"
                                BorderThickness="0.6"
                                Padding="6"
                                ClipToBounds="True">

                          
                            <ItemsControl ItemsSource="{Binding Cells}"
                                          ItemTemplate="{StaticResource TrayCellTemplate}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="{Binding Rows}" Columns="{Binding Cols}"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                        </Border>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <!-- ========= OVERVIEW BOX ========= -->
        <Style x:Key="OvBox" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="#0CFFFFFF"/>
            <Setter Property="BorderThickness" Value="0.6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <Style x:Key="OvKey" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text2Brush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="OvVal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
        
            <ColumnDefinition Width="3.45*"/>
            <ColumnDefinition Width="12"/>
         
            <ColumnDefinition Width="1.15*"/>
        </Grid.ColumnDefinitions>

      
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

         
            <Border Grid.Row="0" Style="{StaticResource ThinCard}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Tray" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding TraySubtitle}" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource ThinPanel}" Padding="8">
                        <!-- 6 tray  -->
                        <ItemsControl ItemsSource="{Binding TrayBoards}"
                                      ItemTemplate="{StaticResource TrayBoardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource ThinCard}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Overview" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Width / Length / Status    |    OK / NG / Total"
                                   Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="2.4*"/>
                        </Grid.ColumnDefinitions>

       
                        <Border Grid.Column="0"
                                CornerRadius="12"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="#0CFFFFFF"
                                BorderThickness="0.6"
                                Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource OvBox}">
                                    <StackPanel>
                                        <TextBlock Text="Width" Style="{StaticResource OvKey}"/>
                                        <TextBlock Text="{Binding WidthMm, StringFormat={}{0:0.##} mm}" Style="{StaticResource OvVal}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource OvBox}">
                                    <StackPanel>
                                        <TextBlock Text="Length" Style="{StaticResource OvKey}"/>
                                        <TextBlock Text="{Binding LengthMm, StringFormat={}{0:0.##} mm}" Style="{StaticResource OvVal}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Style="{StaticResource OvBox}">
                                    <StackPanel>
                                        <TextBlock Text="Status" Style="{StaticResource OvKey}"/>
                                        <TextBlock Text="{Binding ResultText}" Style="{StaticResource OvVal}"
                                                   Foreground="{Binding ResultDotBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

 
                        <Border Grid.Column="2"
                                CornerRadius="12"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="#0CFFFFFF"
                                BorderThickness="0.6"
                                Padding="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource OvBox}">
                                    <StackPanel>
                                        <TextBlock Text="OK" Style="{StaticResource OvKey}"/>
                                        <TextBlock Text="{Binding OkCount}" Style="{StaticResource OvVal}"
                                                   Foreground="{DynamicResource GoodBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource OvBox}">
                                    <StackPanel>
                                        <TextBlock Text="NG" Style="{StaticResource OvKey}"/>
                                        <TextBlock Text="{Binding NgCount}" Style="{StaticResource OvVal}"
                                                   Foreground="{DynamicResource BadBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4" Style="{StaticResource OvBox}">
                                    <StackPanel>
                                        <TextBlock Text="Total" Style="{StaticResource OvKey}"/>
                                        <TextBlock Text="{Binding TotalCount}" Style="{StaticResource OvVal}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                    </Grid>
                </Grid>
            </Border>
        </Grid>


        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
             
                <RowDefinition Height="1.05*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="1.05*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="0.90*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ThinCard}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Cam 1" Style="{StaticResource SectionTitle}"/>

                   
                    <Viewbox Grid.Row="2" Stretch="Uniform" StretchDirection="DownOnly">
                        <Border Width="340" Height="340"
                                CornerRadius="12"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="#0CFFFFFF"
                                BorderThickness="0.6"
                                ClipToBounds="True">
                            <Image Source="{Binding Camera1Image}" Stretch="UniformToFill"/>
                        </Border>
                    </Viewbox>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource ThinCard}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Cam 2" Style="{StaticResource SectionTitle}"/>

                    <Viewbox Grid.Row="2" Stretch="Uniform" StretchDirection="DownOnly">
                        <Border Width="340" Height="340"
                                CornerRadius="12"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="#0CFFFFFF"
                                BorderThickness="0.6"
                                ClipToBounds="True">
                            <Image Source="{Binding Camera2Image}" Stretch="UniformToFill"/>
                        </Border>
                    </Viewbox>
                </Grid>
            </Border>

      
            <Border Grid.Row="4" Style="{StaticResource ThinCard}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Log" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="Realtime messages" Style="{StaticResource Muted}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="2" Style="{StaticResource ThinPanel}" Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding LogLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12"
                                                   Margin="0,0,0,6"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Text="{Binding LatencyText}"
                               Style="{StaticResource Muted}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
